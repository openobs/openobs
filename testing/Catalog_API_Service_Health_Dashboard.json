{
  "id": "mnjumyxe-j26glc",
  "type": "dashboard",
  "title": "Catalog API Service Health Dashboard",
  "description": "Comprehensive monitoring dashboard for catalog-api service health, focusing on request volume, error rate, latency, and inflight traffic using RED methodology.",
  "prompt": "Build a service health dashboard for `catalog-api` with request volume, error rate, latency, and inflight traffic.",
  "userId": "anonymous",
