  "panels": [
    {
      "id": "48066c9f-58c7-47e7-8da8-a5404a4bcf68",
      "title": "Request Rate",
      "description": "Current requests per second from http_requests_total metric",
      "queries": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{service=\"catalog-api\"}[5m]))",
          "instant": true
        }
      ],
      "visualization": "stat",
      "row": 0,
      "col": 0,
      "width": 3,
      "height": 3,
      "refreshIntervalSec": 30,
      "unit": "reqps",
      "decimals": 2,
      "sectionId": "overview",
      "sectionLabel": "Overview"
    },
    {
      "id": "5c5ca725-bce4-42ee-bb45-4ef25f48ce85",
      "title": "Error Rate %",
      "description": "Percentage of requests with errors (4xx/5xx) relative to total requests",
      "queries": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{service=\"catalog-api\", status_code=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total{service=\"catalog-api\"}[5m])) * 100",
          "instant": true
        }
      ],
      "visualization": "stat",
